    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-demos/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6"
  }
}