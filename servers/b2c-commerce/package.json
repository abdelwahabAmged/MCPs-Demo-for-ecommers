{
  "name": "@mcp-demos/b2c-commerce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && cp src/data/*.json dist/data/ && cp -r src/public dist/public",
    "dev": "tsx --env-file=.env --watch src/index.ts",
